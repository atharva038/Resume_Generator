# Production Environment Variables
# This file is used when building for production: npm run build

# Backend API URL (for API calls)
VITE_API_URL=https://api.smartnshine.app/api

# Backend Server URL (for OAuth redirects)
VITE_SERVER_URL=https://api.smartnshine.app

# Razorpay Configuration
# Set the real production key in your deployment provider.
VITE_RAZORPAY_KEY_ID=
